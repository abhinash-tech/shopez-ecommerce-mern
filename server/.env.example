# ============================================================
#  ShopEZ — Environment Variables Template
#  Copy this file to .env and fill in your real values.
#  NEVER commit the actual .env file to version control.
# ============================================================


# ── SERVER ────────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=5000                     # Port the Express server listens on
CLIENT_URL=http://localhost:5173  # Frontend origin (for CORS + OAuth redirects)


# ── MONGODB ───────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/shopez?retryWrites=true&w=majority
# Local dev alternative:
# MONGO_URI=mongodb://127.0.0.1:27017/shopez


# ── JWT ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_super_secret_access_token_key_min_64_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_min_64_chars

JWT_ACCESS_EXPIRES_IN=15m    # Short-lived access token lifetime
JWT_REFRESH_EXPIRES_IN=7d    # Long-lived refresh token lifetime (days)


# ── CLOUDINARY ────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret


# ── GOOGLE OAUTH ──────────────────────────────────────────
# Create at: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback


# ── EMAIL (SendGrid SMTP) ─────────────────────────────────
# Create at: https://app.sendgrid.com/
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USER=apikey
EMAIL_PASS=SG.your_sendgrid_api_key_here
EMAIL_FROM_NAME=ShopEZ
EMAIL_FROM_ADDRESS=noreply@shopez.com


# ── STRIPE PAYMENT GATEWAY ────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_signing_secret


# ── RAZORPAY PAYMENT GATEWAY ─────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret


# ── RATE LIMITING ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes in milliseconds
RATE_LIMIT_MAX=100            # Max requests per window per IP
AUTH_RATE_LIMIT_MAX=10        # Stricter limit for auth endpoints


# ── BCRYPT ────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12         # Bcrypt work factor (12 recommended for production)


# ── COOKIE ────────────────────────────────────────────────
COOKIE_DOMAIN=localhost       # Set to your domain in production (e.g. shopez.com)


# ── LOGS ──────────────────────────────────────────────────
LOG_LEVEL=debug               # debug | info | warn | error
LOG_DIR=logs                  # Directory where log files are written
